# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Backend (Spring Boot microservices via Kong gateway)
# Base URL of the Kong gateway — all admin API calls go through here.
BACKEND_API_URL=http://localhost:8000
# JWT signing secret — MUST match the backend's app.jwt.secret (JWT_SECRET).
# Used to verify the admin JWT in middleware and server components.
JWT_SECRET=change-me-in-production-minimum-32-chars!!

# Supabase — get these from your project's API settings
# (Retained only for backoffice-only data with no backend equivalent:
#  audit logs, custom roles, system config, and entities not yet in the backend.)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_secret_service_role_key_here

# App URL — used in invite emails (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — get your API key from https://resend.com
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_your_api_key_here

# HugeIcons Pro — private npm registry token
HUGEICONS_TOKEN=your_hugeicons_token_here
